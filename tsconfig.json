{
  "compilerOptions": {
    // Module system
    "module": "nodenext",
    "target": "esnext",

    // Node types
    "types": ["node"],

    // Allow default imports from CommonJS (important for Express)
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    // Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Type safety
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,

    // Module handling
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",

    // Performance
    "skipLibCheck": true
  }
}